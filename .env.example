###############################################
# Agent Builder QA - Environment Example
# Copy this file to `.env` and fill in values.
###############################################

# LLM configuration
# Provider for LLMJudge. Supported: "openai", "anthropic", "adxp"
LLM_PROVIDER=adxp

# API key for the selected provider (adxp 사용 시 불필요)
LLM_API_KEY=sk-your-api-key-here

# Default model name for LLMJudge
# For OpenAI: GIP/gpt-4.1, gpt-4o, etc.
# For Anthropic: claude-haiku-4-5-20251001, etc.
# For adxp: serving name (e.g. my-serving)
LLM_MODEL=GIP/gpt-4.1

# adxp LLM Judge endpoint (adxp provider 사용 시)
# Default: https://aip.sktai.io//api/v1/agent_gateway
ADXP_JUDGE_ENDPOINT=https://aip.sktai.io/api/v1/gateway/chat/completions


# Agent Builder backend configuration

# Base URL of the Agent Builder backend
# Default: https://aip.sktai.io/
BASE_URL=https://aip.sktai.io/

# Auth Server (Keycloak) base URL
AUTH_URL=https://aip.sktai.io/

# Project name (Keycloak client_id)
AUTH_CLIENT_ID=default

# Login credentials
AUTH_USERNAME=your-username
AUTH_PASSWORD=your-password


# Scenario selection for CLI mode

# "all" to run every scenario directory under ./scenarios
# or a specific scenario directory name, e.g. "01_simple_chat"
SCENARIO=all

